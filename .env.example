# --- Database Configuration ---
# Sunucunuzdaki PostgreSQL'e bağlanmak için (Host olarak 'host.docker.internal' kullanın)
DATABASE_URL=postgresql://user:password@host.docker.internal:5432/dbname

# --- Port Configuration (Apache/Nginx Reverse Proxy için) ---
# Diğer uygulamalarla çakışmaması için boş bir port seçin
WEB_PORT=18080
API_PORT=18000

# --- Backend Configuration ---
API_BASE_URL=https://api.edugame.korkusuz.gen.tr
SECRET_KEY=generate-a-strong-secret-key-here

# --- Frontend Configuration ---
VITE_API_URL=https://api.edugame.korkusuz.gen.tr
